# Root .gitignore for the combined repo (React prototype at root + flutter/ subapp)

# --- Node / Vite (React prototype) ---
node_modules/
dist/
dist-ssr/
*.local
.vite/

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Editor / OS ---
.DS_Store
.idea/
.vscode/
*.swp

# Note: the Flutter app has its own .gitignore under flutter/ that covers
# build artifacts, .dart_tool, and android/local.properties.

# Python
__pycache__/
*.pyc
